# Copy this file to .env and fill in your values.
# Never commit the actual .env file (it is gitignored).

# Required: Your Zhipu AI API key — get it from open.bigmodel.cn
ZHIPU_API_KEY=sk-your-zhipu-api-key-here

# Model name. glm-4-flash is free/fast for dev. glm-4-5 for production.
GLM_MODEL=glm-4-flash

# Comma-separated CORS allowed origins.
# Local dev only: http://localhost:3000
# Production: add your Vercel deployment URL.
ALLOWED_ORIGINS=http://localhost:3000
